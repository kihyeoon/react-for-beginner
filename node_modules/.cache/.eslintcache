rue);\n  const [movie, setMovie] = useState([]);\n  const getMovie = async () => {\n    const json = await (\n      await fetch(`https://yts.mx/api/v2/movie_details.json?movie_id=${id}`)\n    ).json();\n    setMovie(json.data.movie);\n    setLoading(false);\n  };\n  useEffect(() => {\n    getMovie();\n  }, []);\n  return (\n    <>\n      {loading ? (\n        <div>\n          <h1>Loading...</h1>\n        </div>\n      ) : (\n        <div>\n          <div>\n            <Link to={\"/\"}>Home</Link>\n          </div>\n          <h2>{movie.year}</h2>\n          <h2>rating: {movie.rating}</h2>\n          <h1>{movie.title}</h1>\n          <img src={movie.large_cover_image} alt={movie.id} />\n          <p>{movie.description_full}</p>\n          <h2>Genres</h2>\n          <ul>\n            {movie.genres?.map((g) => (\n              <li key={g}>{g}</li>\n            ))}\n          </ul>\n        </div>\n      )}\n    </>\n  );\n}\nexport default Detail;\n",{"ruleId":"29","severity":1,"message":"30","line":17,"column":6,"nodeType":"31","endLine":17,"endColumn":8,"suggestions":"32"},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'getMovie'. Either include it or remove the dependency array.","ArrayExpression",["33"],{"desc":"34","fix":"35"},"Update the dependencies array to be: [getMovie]",{"range":"36","text":"37"},[487,489],"[getMovie]"]